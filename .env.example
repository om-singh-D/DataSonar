# ============================================
# DataSonar Environment Configuration
# ============================================
# Copy this to .env and fill in your values
# DO NOT commit .env to version control

# General
NODE_ENV=development
LOG_LEVEL=debug

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=datasonar
POSTGRES_USER=datasonar
POSTGRES_PASSWORD=datasonar_secret
DATABASE_URL=postgresql://datasonar:datasonar_secret@localhost:5432/datasonar

# MongoDB
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USER=datasonar
MONGODB_PASSWORD=datasonar_secret
MONGODB_URI=mongodb://datasonar:datasonar_secret@localhost:27017/datasonar?authSource=admin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=datasonar_secret

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=datasonar

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=datasonar
RABBITMQ_PASSWORD=datasonar_secret
RABBITMQ_VHOST=datasonar

# MinIO (S3)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=datasonar
MINIO_SECRET_KEY=datasonar_secret

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=24h